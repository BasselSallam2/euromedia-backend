{
    "compilerOptions": {
        "lib": ["ESNext"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "jsx": "react-jsx",
        "allowJs": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "baseUrl": "./src",
        "paths": {
            "@/*": ["*"],
            "@config/*": ["config/*"],
            "@middlewares/*": ["middlewares/*"],
            "@modules/*": ["modules/*"],
            "@shared/*": ["shared/*"],
            "@types/*": ["types/*"],
            "@utils/*": ["utils/*"],
            "@logs/*": ["LOGS/*"],
            "@cache/*": ["cache/*"],
            "@services/*": ["services/*"],
            "@public/*": ["public/*"],
            "@translation/*": ["translation/*"]
        },
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false,
        "skipLibCheck": true
    }
}
